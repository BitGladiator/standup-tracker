{
  "name": "server",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "migrate:up": "node-pg-migrate up 2>&1 | grep -v \"Can't determine timestamp\"",
    "migrate:down": "node-pg-migrate down 2>&1 | grep -v \"Can't determine timestamp\"",
    "migrate:create": "node-pg-migrate create",
    "migrate:status": "node-pg-migrate status",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPatterns=unit --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPatterns=integration --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "forceExit": true,
    "setupFiles": [
      "<rootDir>/tests/helpers/loadEnv.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "middleware/**/*.js",
      "routes/**/*.js",
      "!services/prReminderService.js",
      "!routes/heatmap.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60
      }
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tests/helpers/setupAfterEnv.js"
    ]
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-slow-down": "^3.1.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "p-limit": "^7.3.0",
    "pg": "^8.11.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.7.0",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
